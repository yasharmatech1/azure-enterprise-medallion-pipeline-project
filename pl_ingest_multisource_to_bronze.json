{
  "name": "pl_ingest_multisource_to_bronze",
  "properties": {
    "activities": [
      {
        "name": "Copy_Source_To_ADLS_Bronze_Volume",
        "type": "Copy",
        "dependsOn": [],
        "policy": {
          "timeout": "0.12:00:00",
          "retry": 3,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "source": {
            "type": "HttpSource",
            "httpRequestTimeout": "00:05:00"
          },
          "sink": {
            "type": "DelimitedTextSink",
            "storeSettings": {
              "type": "AzureBlobFSWriteSettings"
            },
            "formatSettings": {
              "type": "DelimitedTextWriteSettings",
              "quoteAllText": true,
              "fileExtension": ".csv"
            }
          },
          "enableStaging": false
        },
        "inputs": [
          {
            "referenceName": "ls_http_multisource_api",
            "type": "DatasetReference"
          }
        ],
        "outputs": [
          {
            "referenceName": "ls_adls_gen2_bronze",
            "type": "DatasetReference",
            "parameters": {
              "volumePath": "az_prod_catalog/fintech_core_bronze/vlm_raw_landing"
            }
          }
        ]
      }
    ],
    "annotations": ["Core-Banking", "Ingestion"]
  }
}